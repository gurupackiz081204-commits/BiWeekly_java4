class Solution {
    public int findKthLargest(int[] nums, int k) {
        for(int i=0;i<k;i++){
            int max=Integer.MIN_VALUE();
            int index=0;
            for(int j=0;i<nums.length();j++){
                if(nums.[j]>max){
                    max=nums[j];
                    index=j;
                }
            }
            if(i==k-1){
                return max;
            }
            else{
                nums.remove(index);
            }
        }
    }
}
